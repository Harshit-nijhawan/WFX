# Backend Environment Variables
# Copy this file, rename to .env, and fill in your values.
# Add ALL of these as Environment Variables in your Render dashboard.

# Server
PORT=5000
NODE_ENV=production

# Supabase (get from supabase.com → Project → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# JWT — use a strong random string (e.g. openssl rand -base64 32)
JWT_SECRET=replace_with_a_long_random_secret_string

# OpenRouter — for NLQ AI feature (openrouter.ai → Keys)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# HuggingFace — for CLIP semantic search (huggingface.co → Settings → Tokens)
# Token needs: "Make calls to Inference Providers" permission
HUGGINGFACE_TOKEN=hf_your_token_here

# CORS — set this to your exact Vercel frontend URL (no trailing slash)
# Example: https://wfx-erp.vercel.app
FRONTEND_URL=https://your-app.vercel.app
